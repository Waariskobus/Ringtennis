const jwt = require('jsonwebtoken');

function authMiddleware(req, res, next) {
  const token = (req.headers['authorization'] || '').split(' ')[1];
  if (!token) return res.status(401).json({ error: 'No token provided' });
  try {
    req.user = jwt.verify(token, process.env.JWT_SECRET);
    next();
  } catch {
    return res.status(401).json({ error: 'Invalid or expired token' });
  }
}

// SA admin only
function saAdminOnly(req, res, next) {
  if (req.user.role !== 'sa_admin') return res.status(403).json({ error: 'SA Admin access required' });
  next();
}

// SA admin or union admin
function unionAdminUp(req, res, next) {
  if (!['sa_admin', 'union_admin'].includes(req.user.role)) return res.status(403).json({ error: 'Union Admin access required' });
  next();
}

// SA admin, union admin, or club admin
function clubAdminUp(req, res, next) {
  if (!['sa_admin', 'union_admin', 'club_admin'].includes(req.user.role)) return res.status(403).json({ error: 'Club Admin access required' });
  next();
}

module.exports = { authMiddleware, saAdminOnly, unionAdminUp, clubAdminUp };
